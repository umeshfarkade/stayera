<% layout("layouts/boilerplate") %>

    <body>
        <a href="/admin/listing" class="back-btnn">
            <i class="fa-solid fa-arrow-left"></i>
            Back
        </a>
        <div class="edit-page">

            <div class="edit-container">


                <div class="edit-form-card">

                    <h2>Edit Your Listing</h2>
                    <p class="subtitle">
                        Update your property details and keep your listing fresh.
                    </p>

                    <form action="/listings/<%= listing._id %>?_method=PUT" method="POST" enctype="multipart/form-data"
                        class="needs-validation" novalidate>

                        <div class="mb-3">
                            <label>Title</label>
                            <input type="text" name="listing[title]" value="<%= listing.title %>" class="form-control"
                                required>
                        </div>

                        <div class="mb-3">
                            <label>Description</label>

                            <textarea name="listing[description]" class="form-control" rows="4"
                                required><%= listing.description %></textarea>
                        </div>



                        <div class="mb-3">
                            <label>Upload New Image</label>

                            <input type="file" name="listing[image]" class="form-control">
                        </div>

                        <div class="row">

                            <div class="col-md-4 mb-3">
                                <label>Price</label>

                                <input type="number" name="listing[price]" value="<%= listing.price %>"
                                    class="form-control" required>
                            </div>

                            <div class="col-md-8 mb-3">
                                <label>Country</label>

                                <input type="text" name="listing[country]" value="<%= listing.country %>"
                                    class="form-control" required placeholder="Enter the country">
                            </div>

                        </div>

                        <div class="mb-4">
                            <label>Location</label>

                            <input type="text" name="listing[location]" value="<%= listing.location %>"
                                class="form-control" required placeholder=" enter the location ">
                        </div>

                        <button class="update-btn">
                            Update Listing
                        </button>

                    </form>

                </div>

            </div>

        </div>


    </body>