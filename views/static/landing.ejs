<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StayERA</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link rel="stylesheet" href="/css/static/landing.css">

</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark custom-navbar">
        <div class="container">

            <a class="navbar-brand" href="/">
                <img src="
            images/logo (2).png" alt="StayERA Logo" height="50">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse" id="navbarContent">

                <ul class="navbar-nav ms-auto align-items-lg-center">

                    <li class="nav-item">
                        <a class="nav-link" href="/company-details">
                            About
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/terms">
                            Terms
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/privacy">
                            Privacy
                        </a>
                    </li>



                </ul>

            </div>

        </div>
    </nav>


    <section class="hero">
        <div class="container">

            <div class="row align-items-center">

                <!-- Left Content -->
                <div class="col-lg-6 text-lg-start text-center">


                    <h1 class="mb-4">
                        Find Stays You'll Love
                    </h1>

                    <p class="mb-4">
                        Explore unique homes, apartments and vacation stays
                        across India with StayERA.
                    </p>



                    <a href="/listings" class="btn-register"> Explore Stays </a>



                </div>

                <!-- Right Illustration -->
                <div class="col-lg-6 text-center mt-5 mt-lg-0">

                    <div class="hero-card">

                        <i class="fa-solid fa-hotel hero-icon"></i>

                        <h3 class="mt-3">
                            Smart Booking Platform
                        </h3>

                        <p>
                            Browse stays, compare prices,
                            and book instantly.
                        </p>

                        <div class="stats-box">
                            <div>
                                <h4>500+</h4>
                                <span>Properties</span>
                            </div>

                            <div>
                                <h4>50+</h4>
                                <span>Cities</span>
                            </div>

                            <div>
                                <h4>1000+</h4>
                                <span>Guests</span>
                            </div>
                        </div>

                    </div>

                </div>

            </div>

        </div>
    </section>



    <!-- About Section -->
    <section class="container py-5">

        <div class="row align-items-center">

            <div class="col-lg-6">
                <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?w=1200"
                    class="img-fluid rounded shadow" alt="">
            </div>

            <div class="col-lg-6">

                <h2 class="fw-bold mb-3">
                    About StayERA
                </h2>

                <p>
                    StayERA is a modern accommodation platform that helps travelers
                    discover comfortable stays, apartments, hotels, and vacation homes.
                </p>

                <p>
                    Our mission is to make travel easier, safer, and more enjoyable
                    for everyone.
                </p>

            </div>

        </div>

    </section>

    <!-- Features -->
    <section class="container py-5">

        <div class="text-center mb-5">
            <h2 class="fw-bold">
                Why Choose StayERA?
            </h2>
        </div>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="feature-card">
                    <i class="fa-solid fa-house"></i>
                    <h4>Verified Stays</h4>
                    <p>Trusted and verified properties across multiple locations.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <i class="fa-solid fa-location-dot"></i>
                    <h4>Prime Locations</h4>
                    <p>Stay close to the places that matter most.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <i class="fa-solid fa-shield-halved"></i>
                    <h4>Secure Booking</h4>
                    <p>Fast and secure booking process for all users.</p>
                </div>
            </div>

        </div>

    </section>

    <!-- Gallery -->
    <section class="container py-5">

        <div class="text-center mb-5">
            <h2 class="fw-bold">
                Explore Amazing Places
            </h2>
        </div>

        <div class="row g-4">

            <div class="col-md-4">
                <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=800" class="gallery-img">
            </div>

            <div class="col-md-4">
                <img src="https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?w=800" class="gallery-img">
            </div>

            <div class="col-md-4">
                <img src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?w=800" class="gallery-img">
            </div>

        </div>

    </section>

    <!-- CTA -->
    <section class="cta">

        <h2 class="fw-bold mb-3">
            Ready For Your Next Adventure?
        </h2>

        <p class="mb-4">
            Join StayERA and discover your perfect stay today.
        </p>

        <a href="/listings" class="btn btn-light btn-lg">
            Get Started
        </a>

    </section>

</body>

</html>