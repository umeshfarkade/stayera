<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Error <%= statusCode %> | WanderLust</title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

    <!-- AOS Animation -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/error.css">


</head>

<body>
    <div class="error-wrapper">
        <!-- Left Text Section -->
        <div class="error-content" data-aos="fade-right">
            <h1>ERROR <%= statusCode || 404 %>
            </h1>
            <h2>Page Not Found</h2>
            <p>
                <%= message
                    || "The page you are looking for might have been removed, had its name changed, or is temporarily unavailable."
                    %>
            </p>
            <a href="/listings" class="btn-home">GO HOME</a>
        </div>

        <!-- Right Illustration -->
        <div class="error-illustration" data-aos="fade-left">
            <!-- 🖼️ New PNG illustration (free to use) -->
            <img src="/images/ee.png" alt="404 illustration">
        </div>
    </div>

    <!-- AOS Script -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({
            duration: 1000,
            easing: "ease-in-out",
            once: true
        });
    </script>
</body>

</html>